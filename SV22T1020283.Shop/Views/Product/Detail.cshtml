@model SV22T1020283.Models.Catalog.Product
@{
    ViewData["Title"] = Model.ProductName;
    var attributes = ViewBag.Attributes as List<SV22T1020283.Models.Catalog.ProductAttribute>;
    var photos = ViewBag.Photos as List<SV22T1020283.Models.Catalog.ProductPhoto>;
}

<div class="product-detail-page py-5">
    <div class="row g-4">
        <div class="col-lg-5">
            <div class="sticky-top" style="top: 100px; z-index: 1;">
                <div class="card border-0 shadow-luxury rounded-4 overflow-hidden">
                    <div class="main-image-container">
                        <img id="mainImage" 
                             src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)" 
                             class="img-fluid zoom-hover" alt="@Model.ProductName">
                    </div>
                    
                    @if (photos != null && photos.Any())
                    {
                        <div class="card-footer bg-white border-0 p-3">
                            <div class="row g-2">
                                <div class="col-3">
                                    <div class="thumb-wrapper active" onclick="updatePreview('~/images/products/@Model.Photo', this)">
                                        <img src="~/images/products/@Model.Photo" class="img-fluid">
                                    </div>
                                </div>
                                @foreach (var photo in photos.Where(p => !p.IsHidden).Take(3))
                                {
                                    <div class="col-3">
                                        <div class="thumb-wrapper" onclick="updatePreview('~/images/products/@photo.Photo', this)">
                                            <img src="~/images/products/@photo.Photo" class="img-fluid">
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="product-content-card p-4 p-md-5 bg-white shadow-luxury rounded-4 h-100">
                <nav aria-label="breadcrumb" class="mb-3">
                    <ol class="breadcrumb small text-uppercase tracking-widest">
                        <li class="breadcrumb-item"><a href="~/Product" class="text-decoration-none text-muted">Cửa hàng</a></li>
                        <li class="breadcrumb-item active text-gold">Chi tiết</li>
                    </ol>
                </nav>

                <h1 class="fw-800 tracking-tighter mb-2 display-6">@Model.ProductName</h1>
                
                <div class="d-flex gap-2 mb-4">
                    <span class="badge-luxury">@Model.CategoryName</span>
                    <span class="badge-luxury outline">@Model.SupplierName</span>
                </div>

                <div class="price-box-luxury mb-4">
                    <span class="h2 fw-800 text-gold">@Model.Price.ToString("#,##0")</span>
                    <span class="text-muted fs-5"> VNĐ / @Model.Unit</span>
                </div>

                <div class="info-item mb-4">
                    <h6 class="fw-bold text-uppercase small tracking-widest text-dark border-bottom pb-2 mb-3">Mô tả sản phẩm</h6>
                    <p class="text-secondary lh-lg">@Model.ProductDescription</p>
                </div>

                @if (attributes != null && attributes.Any())
                {
                    <div class="info-item mb-5">
                        <h6 class="fw-bold text-uppercase small tracking-widest text-dark border-bottom pb-2 mb-3">Thông số kỹ thuật</h6>
                        <div class="table-responsive">
                            <table class="table table-borderless align-middle">
                                @foreach (var attr in attributes.OrderBy(a => a.DisplayOrder))
                                {
                                    <tr class="border-bottom-faint">
                                        <th class="py-3 text-muted fw-medium" style="width: 35%">@attr.AttributeName</th>
                                        <td class="py-3 fw-bold text-dark text-end">@attr.AttributeValue</td>
                                    </tr>
                                }
                            </table>
                        </div>
                    </div>
                }

                <div class="order-section sticky-bottom-mobile mt-auto pt-4 border-top">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <div class="qty-selector">
                                <button type="button" onclick="changeQty(-1)">-</button>
                                <input type="number" id="quantity" value="1" min="1" readonly>
                                <button type="button" onclick="changeQty(1)">+</button>
                            </div>
                        </div>
                        <div class="col-md-8">
                            <button class="btn-luxury-dark w-100 py-3 fw-bold tracking-widest" onclick="addToCart()">
                                <i class="bi bi-cart-plus me-2"></i> THÊM VÀO GIỎ HÀNG
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Tổng thể Luxury */
    .fw-800 { font-weight: 800; }
    .text-gold { color: #d4af37; }
    .tracking-widest { letter-spacing: 0.15em; }
    .tracking-tighter { letter-spacing: -1px; }
    .shadow-luxury { box-shadow: 0 20px 60px rgba(0,0,0,0.06); }

    /* Fix khung hình chuẩn 1:1 */
    .main-image-container {
        aspect-ratio: 1 / 1; /* Cố định khung hình vuông */
        display: flex;
        align-items: center;
        justify-content: center;
        background: #fff;
        overflow: hidden;
    }
    .main-image-container img {
        max-width: 90%;
        max-height: 90%;
        object-fit: contain;
        transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
    }
    .main-image-container:hover img { transform: scale(1.1); }

    /* Thumbnail Gallery */
    .thumb-wrapper {
        aspect-ratio: 1/1;
        border: 2px solid transparent;
        border-radius: 8px;
        overflow: hidden;
        cursor: pointer;
        padding: 4px;
        transition: 0.3s;
    }
    .thumb-wrapper img { width: 100%; height: 100%; object-fit: contain; }
    .thumb-wrapper.active { border-color: #d4af37; }

    /* Badge & Price */
    .badge-luxury {
        background: #f8f8f8; color: #1a1a1a;
        padding: 6px 14px; border-radius: 50px; font-size: 0.75rem;
        font-weight: 700; text-uppercase: uppercase;
    }
    .badge-luxury.outline { background: transparent; border: 1px solid #eee; }
    .border-bottom-faint { border-bottom: 1px solid #f8f8f8; }

    /* Qty Selector */
    .qty-selector {
        display: flex; background: #f1f1f1; border-radius: 8px; padding: 4px;
    }
    .qty-selector button {
        border: none; background: transparent; width: 40px; height: 40px;
        font-weight: bold; transition: 0.2s;
    }
    .qty-selector button:hover { color: #d4af37; }
    .qty-selector input {
        border: none; background: transparent; text-align: center; width: 100%; font-weight: bold;
    }

    /* Buttons */
    .btn-luxury-dark {
        background: #1a1a1a; color: white; border: none; border-radius: 8px;
        transition: 0.3s;
    }
    .btn-luxury-dark:hover { background: #d4af37; transform: translateY(-2px); }
</style>

@section Scripts {
    <script>
        function updatePreview(url, el) {
            // Fix lỗi ký tự tiếng Việt khi chuyển ảnh
            var cleanUrl = url.replace('~', '');
            $('#mainImage').fadeOut(200, function() {
                $(this).attr('src', cleanUrl).fadeIn(200);
            });
            $('.thumb-wrapper').removeClass('active');
            $(el).addClass('active');
        }

        function changeQty(val) {
            var qty = parseInt($('#quantity').val());
            if (qty + val >= 1) $('#quantity').val(qty + val);
        }

        function addToCart() {
            var productId = @Model.ProductID;
            var quantity = $('#quantity').val();

            $.post('@Url.Action("AddToCart", "Cart")', { productId: productId, quantity: quantity })
                .done(function(response) {
                    if (response.success) {
                        if(typeof updateCartCount === 'function') updateCartCount();
                        
                        Swal.fire({
                            icon: 'success',
                            title: 'Đã thêm vào giỏ hàng',
                            text: '@Html.Raw(Model.ProductName)', // Đã fix lỗi font ở đây
                            confirmButtonColor: '#1a1a1a'
                        });
                    }
                });
        }
    </script>
}