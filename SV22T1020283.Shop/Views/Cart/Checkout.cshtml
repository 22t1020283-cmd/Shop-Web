@using SV22T1020283.Admin
@model List<SV22T1020283.Models.Shop.CartItem>
@{
    ViewData["Title"] = "Hoàn tất đơn hàng";
    decimal total = Model?.Sum(x => x.TotalPrice) ?? 0;
}

<div class="checkout-page-wrapper py-5">
    <div class="container">
        <div class="d-flex align-items-center mb-5 pb-2 border-bottom">
            <i class="bi bi-shield-check text-gold fs-2 me-3"></i>
            <h2 class="fw-800 tracking-tighter mb-0 text-uppercase">Xác nhận thanh toán</h2>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger shadow-sm border-0 rounded-4 mb-4">
                <i class="bi bi-exclamation-triangle me-2"></i> @TempData["Error"]
            </div>
        }

        <div class="row g-5">
            <div class="col-lg-7">
                <div class="checkout-form-card p-4 p-md-5 bg-white shadow-luxury rounded-5">
                    <h5 class="fw-bold text-uppercase tracking-widest small mb-4 border-bottom pb-3">
                        <i class="bi bi-truck me-2 text-gold"></i> Địa chỉ nhận hàng
                    </h5>

                    <form method="post" asp-action="Checkout" id="checkoutForm">
                        <div class="mb-4">
                            <label class="form-label small fw-bold text-muted text-uppercase tracking-widest">Tỉnh/Thành phố <span class="text-danger">*</span></label>
                            <select name="deliveryProvince" class="form-select-luxury" required>
                                <option value="">-- Chọn tỉnh/thành phố --</option>
                                @foreach (var province in await SelectListHelper.Provinces())
                                {
                                    <option value="@province.Value">@province.Text</option>
                                }
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-muted text-uppercase tracking-widest">Địa chỉ chi tiết <span class="text-danger">*</span></label>
                            <textarea name="deliveryAddress" class="form-control-luxury" rows="4" 
                                      placeholder="Số nhà, tên đường, phường/xã..." required></textarea>
                        </div>

                        <div class="payment-method-box p-4 rounded-4 border-gold-light bg-gold-faint mb-4">
                            <div class="d-flex align-items-center mb-2">
                                <i class="bi bi-credit-card-2-front text-gold fs-4 me-3"></i>
                                <h6 class="mb-0 fw-bold">Phương thức thanh toán</h6>
                            </div>
                            <p class="small text-muted mb-0 ps-5">Thanh toán khi nhận hàng (COD). Chúng tôi sẽ kiểm tra và xác nhận đơn hàng của bạn ngay lập tức.</p>
                        </div>
                    </form>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="order-summary-card p-4 bg-white shadow-luxury rounded-5 sticky-top" style="top: 100px;">
                    <h5 class="fw-bold text-uppercase tracking-widest small mb-4 border-bottom pb-3">Đơn hàng của bạn</h5>
                    
                    <div class="order-items-scroll mb-4" style="max-height: 300px; overflow-y: auto;">
                        @foreach (var item in Model)
                        {
                            <div class="d-flex align-items-center mb-3">
                                <div class="position-relative me-3">
                                    <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)" 
                                         class="rounded-3 border" style="width: 60px; height: 60px; object-fit: cover;">
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-dark">
                                        @item.Quantity
                                    </span>
                                </div>
                                <div class="flex-grow-1 overflow-hidden">
                                    <h6 class="small fw-bold mb-0 text-truncate">@item.ProductName</h6>
                                    <span class="small text-muted">@item.Unit</span>
                                </div>
                                <div class="text-end ms-2">
                                    <span class="small fw-bold">@item.TotalPrice.ToString("#,##0") đ</span>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="summary-details border-top pt-3">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Tạm tính</span>
                            <span>@total.ToString("#,##0") đ</span>
                        </div>
                        <div class="d-flex justify-content-between mb-4">
                            <span class="text-muted">Phí vận chuyển</span>
                            <span class="text-success fw-bold">Miễn phí</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <span class="h6 fw-800 mb-0">TỔNG CỘNG</span>
                            <span class="h4 fw-800 text-gold mb-0">@total.ToString("#,##0") đ</span>
                        </div>
                    </div>

                    <button type="submit" form="checkoutForm" class="btn-luxury-dark w-100 py-3 rounded-3 fw-bold tracking-widest">
                        <i class="bi bi-lock-fill me-2"></i> XÁC NHẬN ĐẶT HÀNG
                    </button>
                    
                    <p class="text-center mt-3 mb-0 small text-muted">
                        <i class="bi bi-info-circle me-1"></i> Nhấn xác nhận đồng nghĩa với việc bạn đồng ý với các điều khoản mua sắm.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-800 { font-weight: 800; }
    .text-gold { color: #d4af37; }
    .tracking-widest { letter-spacing: 0.1em; }
    .tracking-tighter { letter-spacing: -1.5px; }
    .shadow-luxury { box-shadow: 0 20px 60px rgba(0,0,0,0.05); }

    /* Inputs Luxury */
    .form-control-luxury, .form-select-luxury {
        width: 100%; padding: 15px; border-radius: 12px;
        border: 1px solid #eee; background-color: #fcfcfc;
        transition: 0.3s;
    }
    .form-control-luxury:focus, .form-select-luxury:focus {
        border-color: #d4af37; box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.05);
        background-color: #fff; outline: none;
    }

    /* Payment Box */
    .border-gold-light { border: 1px solid rgba(212, 175, 55, 0.2); }
    .bg-gold-faint { background-color: rgba(212, 175, 55, 0.03); }

    /* Button Luxury */
    .btn-luxury-dark {
        background: #1a1a1a; color: #fff; border: none;
        transition: 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    }
    .btn-luxury-dark:hover {
        background: #d4af37; transform: translateY(-3px);
        box-shadow: 0 10px 25px rgba(212, 175, 55, 0.2);
        color: #fff;
    }

    /* Custom Scrollbar for Order Items */
    .order-items-scroll::-webkit-scrollbar { width: 4px; }
    .order-items-scroll::-webkit-scrollbar-track { background: #f1f1f1; }
    .order-items-scroll::-webkit-scrollbar-thumb { background: #d4af37; border-radius: 10px; }
</style>