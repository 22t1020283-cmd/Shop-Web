@using SV22T1020283.Models.Sales
@model SV22T1020283.Models.Sales.OrderViewInfo
@{
    ViewData["Title"] = $"Đơn hàng #{Model.OrderID}";
    var details = ViewBag.Details as List<SV22T1020283.Models.Sales.OrderDetailViewInfo>;
    decimal total = details?.Sum(x => x.TotalPrice) ?? 0;
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row g-4">
        <div class="col-md-3">
            <div class="profile-nav d-flex flex-column gap-2">
                <h6 class="text-uppercase small fw-bold text-muted mb-3 px-2">Giao dịch</h6>
                <a href="@Url.Action("Profile", "ShopAccount")" class="nav-item-min">
                    <i class="bi bi-person me-2"></i> Thông tin cá nhân
                </a>
                <a href="@Url.Action("ChangePassword", "ShopAccount")" class="nav-item-min">
                    <i class="bi bi-key me-2"></i> Đổi mật khẩu
                </a>
                <a href="@Url.Action("Index", "Order")" class="nav-item-min active">
                    <i class="bi bi-receipt me-2"></i> Đơn hàng của tôi
                </a>
            </div>
        </div>

        <div class="col-md-9">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-body p-4 p-md-5">
                    
                    <div class="d-flex flex-wrap justify-content-between align-items-end mb-4 pb-4 border-bottom gap-3">
                        <div>
                            <h4 class="fw-800 tracking-tighter mb-1">CHI TIẾT ĐƠN #@Model.OrderID</h4>
                            <p class="text-muted small mb-0">Đặt ngày: @Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                        <div class="text-md-end">
                            <span class="status-badge-detail @Model.Status.ToString().ToLower()">
                                @Model.Status.GetDescription()
                            </span>
                        </div>
                    </div>

                    @if (TempData["Success"] != null) { <div class="alert alert-success border-0 rounded-3 small mb-4">@TempData["Success"]</div> }
                    @if (TempData["Error"] != null) { <div class="alert alert-danger border-0 rounded-3 small mb-4">@TempData["Error"]</div> }

                    <div class="row g-4 mb-5">
                        <div class="col-md-6">
                            <div class="info-block p-3 rounded-4 bg-light h-100">
                                <h6 class="fw-bold small text-uppercase tracking-widest text-muted mb-3">Người nhận hàng</h6>
                                <p class="mb-1 fw-bold text-dark">@Model.CustomerName</p>
                                <p class="mb-1 small">@Model.CustomerPhone</p>
                                <p class="mb-0 small text-muted">@Model.CustomerEmail</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-block p-3 rounded-4 bg-light h-100">
                                <h6 class="fw-bold small text-uppercase tracking-widest text-muted mb-3">Địa chỉ giao hàng</h6>
                                <p class="mb-1 small">@Model.DeliveryAddress</p>
                                <p class="mb-2 small">@Model.DeliveryProvince</p>
                                @if (!string.IsNullOrEmpty(Model.ShipperName))
                                {
                                    <div class="pt-2 border-top mt-2">
                                        <small class="text-gold fw-bold uppercase" style="font-size: 0.65rem;">Đơn vị vận chuyển</small>
                                        <p class="mb-0 small fw-bold">@Model.ShipperName - @Model.ShipperPhone</p>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <h6 class="fw-800 mb-3 tracking-tighter">DANH SÁCH SẢN PHẨM</h6>
                    <div class="table-responsive mb-4">
                        <table class="table-min w-100">
                            <thead>
                                <tr>
                                    <th class="text-muted small uppercase pb-3">Sản phẩm</th>
                                    <th class="text-center text-muted small uppercase pb-3">SL</th>
                                    <th class="text-end text-muted small uppercase pb-3">Đơn giá</th>
                                    <th class="text-end text-muted small uppercase pb-3">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in details)
                                {
                                    <tr>
                                        <td class="py-3">
                                            <div class="d-flex align-items-center gap-3">
                                                <img src="~/images/products/@item.Photo" class="rounded-3 shadow-sm border" style="width: 60px; height: 60px; object-fit: cover;">
                                                <div>
                                                    <p class="mb-0 fw-bold small text-dark">@item.ProductName</p>
                                                    <small class="text-muted">ĐVT: @item.Unit</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center py-3 small">@item.Quantity</td>
                                        <td class="text-end py-3 small">@item.SalePrice.ToString("#,##0") đ</td>
                                        <td class="text-end py-3 fw-bold small text-dark">@item.TotalPrice.ToString("#,##0") đ</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex justify-content-end border-top pt-4">
                        <div class="text-end" style="min-width: 250px;">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted small">Tổng tiền hàng:</span>
                                <span class="small fw-bold">@total.ToString("#,##0") đ</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted small">Phí vận chuyển:</span>
                                <span class="small fw-bold">0 đ</span>
                            </div>
                            <div class="d-flex justify-content-between mt-3 pt-3 border-top">
                                <span class="fw-800 text-dark">TỔNG CỘNG:</span>
                                <span class="fs-4 fw-800 text-gold">@total.ToString("#,##0") đ</span>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 d-flex flex-wrap gap-2 justify-content-between align-items-center">
                        <a href="@Url.Action("Index")" class="btn-min-outline px-4 py-2 text-decoration-none">
                            <i class="bi bi-arrow-left me-2"></i> QUAY LẠI
                        </a>

                        @if (Model.Status == OrderStatusEnum.New)
                        {
                            <form method="post" asp-action="Cancel" onsubmit="return confirm('Bạn có chắc chắn muốn hủy đơn hàng này?')">
                                <input type="hidden" name="id" value="@Model.OrderID" />
                                <button type="submit" class="btn-min-danger px-4 py-2">
                                    HỦY ĐƠN HÀNG
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-800 { font-weight: 800; }
    .tracking-tighter { letter-spacing: -1.5px; }
    .tracking-widest { letter-spacing: 1.5px; }
    .text-gold { color: #d4af37; }
    .uppercase { text-transform: uppercase; }

    /* Nav Item (Kế thừa) */
    .nav-item-min { padding: 10px 15px; border-radius: 8px; color: #555; text-decoration: none; font-size: 0.9rem; font-weight: 600; transition: 0.2s; }
    .nav-item-min:hover { background: #f4f4f4; color: #000; }
    .nav-item-min.active { background: #000; color: #fff; }

    /* Status Badge Detail */
    .status-badge-detail { padding: 8px 16px; border-radius: 50px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; border: 1px solid #eee; }
    .status-badge-detail.new { background: #fff8eb; color: #f39c12; border-color: #f39c12; }
    .status-badge-detail.completed { background: #e8f8f0; color: #27ae60; border-color: #27ae60; }
    .status-badge-detail.cancelled, .status-badge-detail.rejected { background: #fff5f5; color: #e74c3c; border-color: #e74c3c; }

    /* Table Minimal */
    .table-min { border-collapse: collapse; }
    .table-min tr { border-bottom: 1px solid #f8f9fa; }
    .table-min tr:last-child { border-bottom: none; }

    /* Buttons */
    .btn-min-outline { background: #fff; color: #666; border: 1px solid #eee; border-radius: 8px; font-weight: 700; font-size: 0.8rem; transition: 0.3s; }
    .btn-min-outline:hover { background: #f8f9fa; color: #000; }
    
    .btn-min-danger { background: #fff; color: #e74c3c; border: 1px solid #e74c3c; border-radius: 8px; font-weight: 700; font-size: 0.8rem; transition: 0.3s; }
    .btn-min-danger:hover { background: #e74c3c; color: #fff; }
</style>