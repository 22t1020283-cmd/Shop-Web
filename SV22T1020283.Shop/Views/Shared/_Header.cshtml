@using System.Security.Claims
@{
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var displayName = isAuthenticated ? (User.FindFirst("DisplayName")?.Value ?? User.FindFirst(ClaimTypes.Name)?.Value ?? "Người dùng") : "";
    var email = isAuthenticated ? (User.FindFirst(ClaimTypes.Email)?.Value ?? "") : "";
    var firstChar = !string.IsNullOrEmpty(displayName) ? displayName.Substring(0, 1).ToUpper() : "U";
}

<nav class="navbar navbar-expand-lg sticky-top luxury-header py-3">
    <div class="container">
        <a href="~/" class="navbar-brand d-flex align-items-center gap-3">
            <div class="logo-wrapper position-relative">
                <div class="logo-box bg-dark shadow-gold d-flex align-items-center justify-content-center">
                    <i class="bi bi-gem text-gold fs-5"></i>
                </div>
            </div>
            <div class="brand-text d-flex flex-column">
                <span class="fw-800 text-dark fs-4 tracking-tighter lh-1">HIHIHAHA</span>
                <span class="text-gold fw-bold small tracking-widest text-uppercase" style="font-size: 0.65rem;">Couture & Tech</span>
            </div>
        </a>

        <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
            <i class="bi bi-list fs-2 text-dark"></i>
        </button>

        <div class="collapse navbar-collapse" id="mainNavbar">
            <ul class="navbar-nav mx-auto mb-2 mb-lg-0 gap-lg-4">
                <li class="nav-item">
                    <a href="~/" class="nav-link-luxury @(Context.Request.Path == "/" ? "active" : "")">Khám phá</a>
                </li>
                <li class="nav-item">
                    <a href="~/Product" class="nav-link-luxury @(Context.Request.Path.StartsWithSegments("/Product") ? "active" : "")">Sản phẩm</a>
                </li>
                <li class="nav-item">
                    <a href="~/Cart" class="nav-link-luxury @(Context.Request.Path.StartsWithSegments("/Cart") ? "active" : "")">Giỏ hàng</a>
                </li>
            </ul>

            <div class="d-flex align-items-center gap-4">
                <div class="search-trigger d-none d-md-block text-dark hover-gold cursor-pointer transition">
                    <i class="bi bi-search fs-5"></i>
                </div>

                <a href="~/Cart" class="cart-icon-wrapper position-relative text-dark transition hover-gold">
                    <i class="bi bi-bag fs-4"></i>
                    <span id="cartCount" class="cart-badge-luxury">0</span>
                </a>

                <div class="header-divider d-none d-lg-block"></div>

                @if (isAuthenticated)
                {
                    <div class="dropdown">
                        <a href="#" class="d-flex align-items-center gap-2 text-decoration-none dropdown-toggle no-caret p-1 rounded-pill hover-soft transition" data-bs-toggle="dropdown">
                            <div class="user-avatar-luxury">
                                <span>@firstChar</span>
                            </div>
                            <span class="d-none d-xl-inline text-dark fw-bold small">@displayName</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow-luxury border-0 p-3 mt-3 animate slideIn">
                            <li class="p-3 mb-3 rounded-4 bg-gold-soft d-flex align-items-center gap-3">
                                <div class="user-avatar-gold">@firstChar</div>
                                <div class="overflow-hidden text-start">
                                    <p class="mb-0 fw-bold text-dark text-truncate">@displayName</p>
                                    <p class="mb-0 text-muted small text-truncate">@email</p>
                                </div>
                            </li>
                            <li><a class="dropdown-item luxury-item" href="~/ShopAccount/Profile"><i class="bi bi-person-circle me-2"></i> Hồ sơ cá nhân</a></li>
                            <li><a class="dropdown-item luxury-item" href="~/Order"><i class="bi bi-receipt-cutoff me-2"></i> Lịch sử đơn hàng</a></li>
                            <li><hr class="dropdown-divider opacity-50"></li>
                            <li><a class="dropdown-item luxury-item text-danger" href="~/ShopAccount/Logout"><i class="bi bi-box-arrow-right me-2"></i> Đăng xuất</a></li>
                        </ul>
                    </div>
                }
                else
                {
                    <div class="auth-group d-flex align-items-center gap-2">
                        <a href="~/ShopAccount/Login" class="btn btn-link text-decoration-none text-dark fw-bold small d-none d-sm-block hover-gold transition">    Đăng nhập
</a>
                        <a href="~/ShopAccount/Register" class="btn-luxury-dark rounded-0 px-4 py-2 small fw-bold">    Đăng ký
</a>
                    </div>
                }
            </div>
        </div>
    </div>
</nav>

<style>
    :root {
        --luxury-gold: #d4af37;
        --luxury-black: #1a1a1a;
        --soft-gray: #f8f8f8;
    }

    .luxury-header {
        background-color: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border-bottom: 1px solid rgba(0,0,0,0.05);
        z-index: 1050;
    }

    /* Logo Styling */
    .logo-box {
        width: 42px; height: 42px; border-radius: 12px;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .shadow-gold { box-shadow: 0 4px 15px rgba(212, 175, 55, 0.25); }
    .text-gold { color: var(--luxury-gold); }
    .fw-800 { font-weight: 800; }
    .tracking-tighter { letter-spacing: -1.5px; }

    .navbar-brand:hover .logo-box {
        transform: rotate(-10deg) scale(1.1);
        background-color: var(--luxury-gold) !important;
    }
    .navbar-brand:hover .bi-gem { color: white; }

    /* Nav Links */
    .nav-link-luxury {
        color: #666;
        font-weight: 600;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        position: relative;
        text-decoration: none;
        transition: color 0.3s ease;
    }
    .nav-link-luxury::after {
        content: ''; position: absolute; width: 0; height: 1px;
        bottom: -2px; left: 0; background-color: var(--luxury-gold);
        transition: width 0.3s ease;
    }
    .nav-link-luxury:hover::after, .nav-link-luxury.active::after { width: 100%; }
    .nav-link-luxury:hover, .nav-link-luxury.active { color: var(--luxury-black) !important; }

    /* Icons & Badge */
    .cart-badge-luxury {
        position: absolute; top: -5px; right: -8px;
        background: var(--luxury-gold); color: white;
        font-size: 0.65rem; font-weight: bold;
        width: 18px; height: 18px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        border: 2px solid white;
    }

    /* User Avatar */
    .user-avatar-luxury {
        width: 38px; height: 38px;
        background: var(--luxury-black); color: var(--luxury-gold);
        border-radius: 50%; display: flex; align-items: center; justify-content: center;
        font-weight: bold; border: 2px solid #eee;
    }
    .user-avatar-gold {
        width: 48px; height: 48px;
        background: var(--luxury-gold); color: white;
        border-radius: 14px; display: flex; align-items: center; justify-content: center;
        font-weight: 800; font-size: 1.3rem;
    }
    .bg-gold-soft { background-color: #fcf9f0; }

    /* Buttons */
    .btn-luxury-dark {
        background: var(--luxury-black); color: white;
        border: none; transition: all 0.3s;
        letter-spacing: 1px;
    }
    .btn-luxury-dark:hover {
        background: var(--luxury-gold);
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(212, 175, 55, 0.3);
    }

    /* Menu Items */
    .luxury-item {
        padding: 10px 15px; font-weight: 500; font-size: 0.9rem;
        transition: all 0.3s;
    }
    .luxury-item:hover {
        background-color: var(--soft-gray);
        color: var(--luxury-gold);
        transform: translateX(5px);
    }

    .header-divider {
        width: 1px; height: 25px; background: #eee;
    }

    .cursor-pointer { cursor: pointer; }
    .hover-gold:hover { color: var(--luxury-gold) !important; }
</style>