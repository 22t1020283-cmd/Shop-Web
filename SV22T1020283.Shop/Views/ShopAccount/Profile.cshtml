@using SV22T1020283.Admin
@model SV22T1020283.Models.Shop.UpdateProfileViewModel
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row g-4">
        <div class="col-md-3">
            <div class="profile-nav d-flex flex-column gap-2">
                <h6 class="text-uppercase small fw-bold text-muted mb-3 px-2" style="letter-spacing: 1px;">Tài khoản</h6>
                <a href="@Url.Action("Profile")" class="nav-item-min active">
                    <i class="bi bi-person me-2"></i> Thông tin cá nhân
                </a>
                <a href="@Url.Action("ChangePassword")" class="nav-item-min">
                    <i class="bi bi-key me-2"></i> Đổi mật khẩu
                </a>
                <a href="@Url.Action("Index", "Order")" class="nav-item-min">
                    <i class="bi bi-receipt me-2"></i> Đơn hàng của tôi
                </a>
            </div>
        </div>

        <div class="col-md-9">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 p-md-5">
                    <div class="mb-4 pb-2 border-bottom">
                        <h4 class="fw-800 mb-0" style="letter-spacing: -1px;">HỒ SƠ CỦA BẠN</h4>
                        <p class="text-muted small mt-1">Quản lý thông tin cá nhân để bảo mật tài khoản</p>
                    </div>

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success border-0 rounded-3 small mb-4">
                            <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
                        </div>
                    }

                    <form method="post" asp-action="Profile">
                        <input type="hidden" asp-for="CustomerID" />

                        <div class="row g-3">
                            <div class="col-md-6 mb-2">
                                <label asp-for="CustomerName" class="form-label-min">Họ tên</label>
                                <input asp-for="CustomerName" class="form-control-min" placeholder="Nhập họ tên..." />
                                <span asp-validation-for="CustomerName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-2">
                                <label asp-for="Email" class="form-label-min">Email</label>
                                <input asp-for="Email" class="form-control-min" type="email" placeholder="email@example.com" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-2">
                                <label asp-for="ContactName" class="form-label-min">Tên giao dịch</label>
                                <input asp-for="ContactName" class="form-control-min" />
                            </div>

                            <div class="col-md-6 mb-2">
                                <label asp-for="Phone" class="form-label-min">Số điện thoại</label>
                                <input asp-for="Phone" class="form-control-min" />
                            </div>

                            <div class="col-md-6 mb-2">
                                <label asp-for="Province" class="form-label-min">Tỉnh/Thành phố</label>
                                <select asp-for="Province" class="form-select-min" asp-items="await SelectListHelper.Provinces()">
                                    <option value="">-- Chọn tỉnh/thành phố --</option>
                                </select>
                            </div>

                            <div class="col-12 mb-2">
                                <label asp-for="Address" class="form-label-min">Địa chỉ chi tiết</label>
                                <textarea asp-for="Address" class="form-control-min" rows="2"></textarea>
                            </div>
                        </div>

                        <div class="mt-4 pt-3 d-flex justify-content-end">
                            <button type="submit" class="btn-min-dark px-5 py-2">
                                <i class="bi bi-save me-2"></i> LƯU THAY ĐỔI
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-800 { font-weight: 800; }
    
    /* Sidebar Navigation Minimal */
    .nav-item-min {
        padding: 10px 15px;
        border-radius: 8px;
        color: #555;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 600;
        transition: 0.2s;
    }
    .nav-item-min:hover { background: #f4f4f4; color: #000; }
    .nav-item-min.active { background: #000; color: #fff; }

    /* Form Inputs Minimal */
    .form-label-min {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        color: #999;
        margin-bottom: 5px;
        display: block;
    }
    .form-control-min, .form-select-min {
        border: 1px solid #eee;
        background: #fafafa;
        border-radius: 8px;
        padding: 10px 12px;
        font-size: 0.95rem;
        width: 100%;
        transition: 0.3s;
    }
    .form-control-min:focus, .form-select-min:focus {
        border-color: #000;
        background: #fff;
        outline: none;
        box-shadow: 0 4px 10px rgba(0,0,0,0.02);
    }

    /* Button Minimal */
    .btn-min-dark {
        background: #1a1a1a;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-weight: 700;
        font-size: 0.85rem;
        transition: 0.3s;
    }
    .btn-min-dark:hover {
        background: #d4af37; /* Màu Gold làm điểm nhấn khi hover */
        transform: translateY(-1px);
    }
</style>